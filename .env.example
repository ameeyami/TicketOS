NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional — enables REAL AI triage (Claude classifies incoming tickets).
# Without it, TicketOS falls back to a built-in heuristic and still works.
ANTHROPIC_API_KEY=
# Optional — override the triage model (default: claude-opus-4-8).
# For cheaper/faster triage use: claude-haiku-4-5 or claude-sonnet-4-6
# TICKETOS_TRIAGE_MODEL=claude-opus-4-8

# Optional — enables REAL email notifications (onboarding welcome,
# offboarding notice, password-reset alerts). Without both, TicketOS still
# creates the ticket + audit trail and just skips the email.
# Get a key at resend.com, then verify a sending domain (or use the
# onboarding@resend.dev test sender, which only delivers to your own address).
RESEND_API_KEY=
# The "From" address. Must be on a domain you've verified in Resend.
# Example: TicketOS <notifications@yourdomain.com>
EMAIL_FROM=
