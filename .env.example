NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional — enables the public REST API (/api/v1/tickets) and the embeddable
# self-service widget. These run without a user session, so they need the
# server-only service_role secret (Supabase → Project Settings → API →
# service_role). Keep it secret — never expose it to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Optional — enables REAL AI triage (Claude classifies incoming tickets).
# Without it, TicketOS falls back to a built-in heuristic and still works.
ANTHROPIC_API_KEY=
# Optional — override the triage model (default: claude-opus-4-8).
# For cheaper/faster triage use: claude-haiku-4-5 or claude-sonnet-4-6
# TICKETOS_TRIAGE_MODEL=claude-opus-4-8

# Optional — enables REAL email notifications (onboarding welcome,
# offboarding notice, password-reset alerts). Without any of these, TicketOS
# still creates the ticket + audit trail and just skips the email.
#
# --- Option 1: Gmail (simplest — no domain needed) ---
# Sends from your Gmail address. Turn on 2-Step Verification, then create an
# app password at https://myaccount.google.com/apppasswords and paste it below.
GMAIL_USER=
GMAIL_APP_PASSWORD=
# Optional display name shown to recipients (defaults to "TicketOS").
# EMAIL_FROM_NAME=TicketOS
#
# --- Option 2: Resend (needs a verified domain) ---
# RESEND_API_KEY=
# EMAIL_FROM=TicketOS <notifications@yourdomain.com>

# Optional — enables a REAL Slack provider action (post a message) with
# one-click rollback (deletes it). Create a Slack app, add the chat:write bot
# scope, install it, invite the bot to a channel, then set:
SLACK_BOT_TOKEN=
# Channel id (e.g. C0123ABCD) or #channel-name the bot has been invited to.
SLACK_DEFAULT_CHANNEL=

# Optional — enables a REAL Jira action (create issue) with one-click rollback
# (deletes it). Create an API token at id.atlassian.com/manage-profile/security/api-tokens.
JIRA_BASE_URL=
# e.g. https://your-domain.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=
# The project key new issues are created in, e.g. OPS.
JIRA_PROJECT_KEY=
